# Пример .env (bootstrap.sh создаёт его сам). Переопределяет порты хоста,
# публичный IP, bearer-токен и TLS. Реально нужен только если запускаешь
# compose руками, минуя bootstrap.
SERVER_IP=127.0.0.1
HEDGEHOG_TOKEN=
HEDGEHOG_TLS=1
HEDGEHOG_WS_PORT=8765
HEDGEHOG_FILE_PORT=8767
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
