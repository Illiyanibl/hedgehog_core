# Caddy — ingress Ёжика. Заложен сразу, но активен только при наличии домена.
#
# Без домена: приложения доступны по IP:port напрямую, Caddy простаивает
#   (эта заглушка на :80). Есть домен: агент через admin API (:2019) добавляет
#   маршрут app.domain → SERVER_IP:PORT, сертификат берётся on-demand.
{
	admin 0.0.0.0:2019

	# On-demand TLS: серт выпускается по мере запросов, НО только для хостов,
	# которые Ёжик подтвердил как зарегистрированное приложение (ask-эндпоинт).
	# Эндпоинт /caddy/ask на файл-сервере Ёжика подключается позже (домен);
	# пока домена/маршрутов нет — on-demand не срабатывает, ошибок не даёт.
	on_demand_tls {
		ask http://hedgehog:8767/caddy/ask
		interval 2m
		burst 5
	}
}

# База: пока нет домена и маршрутов — простая заглушка, чтобы Caddy стартовал.
# Реальные маршруты приложений агент добавляет динамически через admin API.
:80 {
	respond "hedgehog ingress" 200
}
